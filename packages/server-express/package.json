{
    "name": "@cascaide-ts/server-express",
    "version": "0.5.1",
    "license": "MIT",
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch"
    },
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "express": "^5.0.0",
        "@cascaide-ts/core": "workspace:*"
    },
    "devDependencies": {
        "express": "^5.0.0",
        "@cascaide-ts/core": "workspace:*",
        "tsup": "^8.0.0",
        "@types/express": "^5.0.0"
    }
}
