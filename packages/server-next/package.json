  "peerDependencies": {
    "next": ">=13",
    "react": ">=18",
    "@cascaide-ts/core": "workspace:*"
  },
  "devDependencies": {
    "@cascaide-ts/core": "workspace:*",
    "tsup": "^8.0.0",
    "next": ">=13",
    "react": ">=18"
  }
}
